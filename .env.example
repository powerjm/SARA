# Copy to .env and fill in. .env is gitignored.
#
# ---- Backend credentials ----
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=

# Override default endpoints if needed (e.g., local LM Studio).
LMSTUDIO_BASE_URL=http://127.0.0.1:1234/v1
LMSTUDIO_API_KEY=lm-studio

# ---- Run harness ----
# Backstop against runaway loops.
RUN_TOKEN_CAP=200000
# Hard cap on wall-clock seconds per run.
RUN_WALL_CLOCK_CAP_SECONDS=1800
# Where to write run records. Override for shared storage in cloud runs.
RUN_OUTPUT_DIR=./runs

# ---- Validator ----
# Container image used for sandboxed payload execution. Pinned by digest in prod.
VALIDATOR_IMAGE=agentic-rop-sandbox:latest

# ---- Logging ----
LOG_LEVEL=INFO
